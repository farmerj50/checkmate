# Vite loads this file automatically in development (npm run dev)
# Replace the VITE_FIREBASE_* values with your real Firebase project credentials.
# Until then, the app runs in demo mode (no real auth required).

VITE_FIREBASE_API_KEY=demo
VITE_FIREBASE_AUTH_DOMAIN=demo
VITE_FIREBASE_PROJECT_ID=demo
VITE_FIREBASE_STORAGE_BUCKET=demo
VITE_FIREBASE_MESSAGING_SENDER_ID=demo
VITE_FIREBASE_APP_ID=demo
